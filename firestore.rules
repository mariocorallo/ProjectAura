rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny
    match /{document=**} { allow read, write: if false; }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == userId 
        && incoming().email == request.auth.token.email
        && incoming().keys().hasAll(['uid', 'email'])
        && incoming().keys().size() >= 2;
      allow update: if isOwner(userId) 
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // Exercise History
    match /users/{userId}/history/{exerciseId} {
      allow list, get: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && isValidId(exerciseId)
        && incoming().exerciseId == exerciseId
        && incoming().lastAccessed == request.time.toMillis()
        && incoming().completedCount is number;
      allow delete: if isOwner(userId);
    }

    // Journal Entries
    match /users/{userId}/journal/{entryId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(entryId)
        && incoming().exerciseId is string
        && incoming().timestamp == request.time.toMillis()
        && incoming().content is string && incoming().content.size() <= 2000;
      allow update: if isOwner(userId)
        && incoming().exerciseId == existing().exerciseId
        && incoming().timestamp == existing().timestamp
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mood'])
        && incoming().content is string && incoming().content.size() <= 2000;
      allow delete: if isOwner(userId);
    }
  }
}
