{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Public and private user data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "history": {
      "title": "User Exercise History",
      "description": "Records of exercises practiced by the user",
      "type": "object",
      "properties": {
        "exerciseId": { "type": "string" },
        "lastAccessed": { "type": "number" },
        "completedCount": { "type": "number" }
      },
      "required": ["exerciseId", "lastAccessed", "completedCount"]
    },
    "journalEntry": {
      "title": "Journal Entry",
      "description": "User's thoughts and reflections",
      "type": "object",
      "properties": {
        "exerciseId": { "type": "string" },
        "timestamp": { "type": "number" },
        "content": { "type": "string" },
        "mood": { "type": "string" }
      },
      "required": ["exerciseId", "timestamp", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "Core user information"
    },
    "/users/{userId}/history/{exerciseId}": {
      "schema": "history",
      "description": "History of completed exercises per user"
    },
    "/users/{userId}/journal/{entryId}": {
      "schema": "journalEntry",
      "description": "User reflections and notes"
    }
  }
}
